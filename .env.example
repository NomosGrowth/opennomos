# Copy values into .env or edit .env directly.
# Shell environment variables take precedence over values defined here.

OPENNOMOS_MCP_BASE_URL=https://api.opennomos.com
OPENNOMOS_MCP_KEY=xxx
OPENNOMOS_ACCOUNT_EMAIL=xxx
OPENNOMOS_ACCOUNT_PASSWORD=xxx

# Content-package defaults for C-class tasks.
# These values control which platform packages get generated when the operator
# wants daily content output without auto-publishing.

# Comma-separated platform ids. These ids also become folder names under:
# artifacts/content/YYYY-MM-DD/<platform>/
OPENNOMOS_CONTENT_PLATFORMS=x,wechat,xiaohongshu

# Default language fallback when a platform-specific language is not set.
OPENNOMOS_CONTENT_DEFAULT_LANGUAGE=zh-CN

# Platform config naming rule:
# OPENNOMOS_CONTENT_PLATFORM_<PLATFORM_KEY>_<FIELD>=...
# PLATFORM_KEY is the uppercased platform id:
# - x -> X
# - wechat -> WECHAT
# - xiaohongshu -> XIAOHONGSHU
#
# Supported fields:
# - NAME: display label used in content packages
# - LANGUAGE: zh-CN, en, en-US, etc.
# - CHAR_LIMIT: leave blank for long-form platforms without a hard target
# - URL_LENGTH: fixed URL character cost for platforms such as X
# - REQUIRES_IMAGE: true or false
# - IMAGE_COUNT: expected image count when images are required
# - NOTES: extra operator guidance for that platform

OPENNOMOS_CONTENT_PLATFORM_X_NAME=X
OPENNOMOS_CONTENT_PLATFORM_X_LANGUAGE=zh-CN
OPENNOMOS_CONTENT_PLATFORM_X_CHAR_LIMIT=280
OPENNOMOS_CONTENT_PLATFORM_X_URL_LENGTH=23
OPENNOMOS_CONTENT_PLATFORM_X_REQUIRES_IMAGE=false
OPENNOMOS_CONTENT_PLATFORM_X_IMAGE_COUNT=0
OPENNOMOS_CONTENT_PLATFORM_X_NOTES=Short post-ready copy with direct link and minimal hashtags.

OPENNOMOS_CONTENT_PLATFORM_WECHAT_NAME=WeChat
OPENNOMOS_CONTENT_PLATFORM_WECHAT_LANGUAGE=zh-CN
OPENNOMOS_CONTENT_PLATFORM_WECHAT_CHAR_LIMIT=
OPENNOMOS_CONTENT_PLATFORM_WECHAT_URL_LENGTH=
OPENNOMOS_CONTENT_PLATFORM_WECHAT_REQUIRES_IMAGE=true
OPENNOMOS_CONTENT_PLATFORM_WECHAT_IMAGE_COUNT=1
OPENNOMOS_CONTENT_PLATFORM_WECHAT_NOTES=Long-form article or note with title options, summary, and cover text.

OPENNOMOS_CONTENT_PLATFORM_XIAOHONGSHU_NAME=Xiaohongshu
OPENNOMOS_CONTENT_PLATFORM_XIAOHONGSHU_LANGUAGE=zh-CN
OPENNOMOS_CONTENT_PLATFORM_XIAOHONGSHU_CHAR_LIMIT=1000
OPENNOMOS_CONTENT_PLATFORM_XIAOHONGSHU_URL_LENGTH=
OPENNOMOS_CONTENT_PLATFORM_XIAOHONGSHU_REQUIRES_IMAGE=true
OPENNOMOS_CONTENT_PLATFORM_XIAOHONGSHU_IMAGE_COUNT=3
OPENNOMOS_CONTENT_PLATFORM_XIAOHONGSHU_NOTES=Short-paragraph note style with a strong hook and clear cover idea.
